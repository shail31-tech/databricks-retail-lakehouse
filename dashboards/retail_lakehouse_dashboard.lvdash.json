{
  "datasets": [
    {
      "name": "kpis",
      "displayName": "Executive KPIs",
      "queryLines": [
        "select\n",
        "  cast(sum(net_revenue) as double) as net_revenue,\n",
        "  sum(net_units) as net_units,\n",
        "  sum(invoice_count) as invoice_count,\n",
        "  max(customer_count) as customer_count,\n",
        "  sum(line_count) as line_count\n",
        "from workspace.gold.daily_sales\n"
      ]
    },
    {
      "name": "daily_sales",
      "displayName": "Daily Sales",
      "queryLines": [
        "select\n",
        "  event_date,\n",
        "  cast(net_revenue as double) as net_revenue,\n",
        "  net_units,\n",
        "  invoice_count,\n",
        "  customer_count,\n",
        "  cancellation_lines\n",
        "from workspace.gold.daily_sales\n",
        "order by event_date\n"
      ]
    },
    {
      "name": "country_revenue",
      "displayName": "Revenue by Country",
      "queryLines": [
        "select\n",
        "  country,\n",
        "  cast(net_revenue as double) as net_revenue,\n",
        "  line_count,\n",
        "  invoice_count,\n",
        "  customer_count\n",
        "from workspace.gold.country_revenue\n",
        "order by net_revenue desc\n"
      ]
    },
    {
      "name": "top_products",
      "displayName": "Top Products",
      "queryLines": [
        "select\n",
        "  product_name,\n",
        "  product_id,\n",
        "  cast(net_revenue as double) as net_revenue,\n",
        "  net_units,\n",
        "  invoice_count,\n",
        "  line_count\n",
        "from workspace.gold.product_performance\n",
        "order by net_revenue desc\n",
        "limit 15\n"
      ]
    },
    {
      "name": "order_status",
      "displayName": "Order Status",
      "queryLines": [
        "select\n",
        "  order_status,\n",
        "  cast(net_revenue as double) as net_revenue,\n",
        "  net_units,\n",
        "  invoice_count,\n",
        "  line_count\n",
        "from workspace.gold.order_status_summary\n",
        "order by net_revenue desc\n"
      ]
    },
    {
      "name": "pipeline_health",
      "displayName": "Pipeline Health",
      "queryLines": [
        "select\n",
        "  pipeline_step,\n",
        "  last_status,\n",
        "  last_run_at,\n",
        "  case when last_status = 'success' then 1 else 0 end as success_flag\n",
        "from workspace.gold.pipeline_health\n",
        "order by pipeline_step\n"
      ]
    }
  ],
