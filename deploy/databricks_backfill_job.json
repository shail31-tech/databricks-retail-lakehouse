{
  "name": "retail-lakehouse-backfill",
  "max_concurrent_runs": 1,
  "parameters": [
    {"name": "start_date", "default": "2010-12-01"},
    {"name": "end_date", "default": "2010-12-03"},
    {"name": "limit_per_day", "default": "1000"},
    {"name": "run_prefix", "default": "databricks-backfill-demo"}
  ],
  "job_clusters": [
    {
      "job_cluster_key": "retail_lakehouse_single_node",
      "new_cluster": {
        "spark_version": "15.4.x-scala2.12",
        "node_type_id": "i3.xlarge",
        "num_workers": 0,
        "spark_conf": {
          "spark.databricks.cluster.profile": "singleNode",
          "spark.master": "local[*]"
        },
        "custom_tags": {
          "ResourceClass": "SingleNode"
        }
      }
    }
  ],
  "tasks": [
    {
      "task_key": "backfill_pipeline",
      "job_cluster_key": "retail_lakehouse_single_node",
      "spark_python_task": {
        "python_file": "/Workspace/Users/shailus2002@gmail.com/retail-lakehouse-files/databricks/backfill_databricks.py",
        "source": "WORKSPACE",
        "parameters": [
          "--start-date", "{{job.parameters.start_date}}",
          "--end-date", "{{job.parameters.end_date}}",
          "--limit-per-day", "{{job.parameters.limit_per_day}}",
          "--config", "/Workspace/Users/shailus2002@gmail.com/retail-lakehouse-files/config/databricks.yml",
          "--run-prefix", "{{job.parameters.run_prefix}}"
        ]
      },
      "libraries": [
        {"pypi": {"package": "pandas>=2.2.0"}},
        {"pypi": {"package": "openpyxl>=3.1.0"}},
        {"pypi": {"package": "pyyaml>=6.0.0"}}
      ]
    }
  ]
}
